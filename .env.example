# MetGate — endpoint et token applicatif
# Copier ce fichier en .env et remplir les valeurs. Ne JAMAIS committer .env.
METGATE_BASE_URL=https://metgate-int.meteo.fr
METGATE_TOKEN=

# Serveur portail
PORT=8080

# Cache TTL (secondes) sur les réponses MetGate. 0 désactive.
METGATE_CACHE_TTL_SECONDS=60
