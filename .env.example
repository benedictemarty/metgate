# MetGate — endpoint et token applicatif
# Copier ce fichier en .env et remplir les valeurs. Ne JAMAIS committer .env.
METGATE_BASE_URL=https://metgate-int.meteo.fr
METGATE_TOKEN=

# Serveur portail
PORT=8080

# Cache TTL (secondes) sur les réponses MetGate. 0 désactive.
METGATE_CACHE_TTL_SECONDS=60

# OpenSky Network (suivi ADS-B). Compte gratuit sur opensky-network.org.
# Auth OAuth2 (méthode actuelle, depuis fin 2024) — generer un client API
# dans Personal Account Settings → Download credentials → JSON {clientId, clientSecret}
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# Auth Basic (legacy, encore acceptée pour les anciens comptes)
OPENSKY_USER=
OPENSKY_PASS=
